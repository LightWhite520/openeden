# OpenEden local runtime configuration
# Copy this file to .env and replace the API key before starting.

# LLM provider
OPENEDEN_LLM_PROVIDER=openai
OPENEDEN_OPENAI_API_KEY=replace-with-your-api-key
OPENEDEN_OPENAI_MODEL=gpt-5.5
# LLM reasoning intensity: low, medium, or high.
OPENEDEN_LLM_REASONING_EFFORT=medium
# Optional OpenAI-compatible relay endpoint.
OPENEDEN_OPENAI_BASE_URL=https://api.openai.com/v1

# Local session and persistence
OPENEDEN_LOCAL_USER_ID=local
OPENEDEN_SERVER_URL=http://127.0.0.1:8080
OPENEDEN_RUNTIME_DB_PATH=data/runtime/openeden.db
OPENEDEN_PERSONA_PATH=persona/default.yaml
OPENEDEN_LOCAL_MODEL_ARTIFACT=data/models/local-model-artifact.json

# Production local model backend
OPENEDEN_MODEL_BACKEND=djl
OPENEDEN_DJL_VQVAE_MODEL_PATH=data/models/djl/vqvae
OPENEDEN_DJL_TEXT_MODEL_PATH=data/models/djl/text
OPENEDEN_DJL_EMOTIONAL_MODEL_PATH=data/models/djl/emotional
OPENEDEN_DJL_AFFECT_MODEL_PATH=data/models/thymos-6d
OPENEDEN_DJL_AFFECT_MODEL_URL=https://huggingface.co/0x4C57/Thymos-6D/resolve/main
OPENEDEN_THYMOS_DEVICE=auto
OPENEDEN_DJL_ENGINE=PyTorch
OPENEDEN_DJL_MODEL_NAME=model

# Optional heartbeat owner delivery target
# OPENEDEN_OWNER_PLATFORM=QQ
# OPENEDEN_OWNER_USER_ID=123456

# Optional authoritative host identity (independent from heartbeat delivery)
# OPENEDEN_HOST_PLATFORM=QQ
# OPENEDEN_HOST_USER_ID=123456
# OPENEDEN_HOST_ADDRESS=主人

# Hidden-by-default CLI diagnostics panel. Keep disabled unless operating locally.
OPENEDEN_ENABLE_CLI_DIAGNOSTICS=false
# OPENEDEN_CLI_DIAGNOSTICS_TOKEN=replace-with-a-local-secret

# Redirected streams use UTF-8.
